# CortexOps backend — environment variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── App ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # set to false in production

# ── Database ───────────────────────────────────────────────────────────────
# Local SQLite (default, no setup required):
DATABASE_URL=sqlite+aiosqlite:///./cortexops.db

# Production PostgreSQL (recommended for hosted deployments):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/cortexops

# ── Redis (required for Celery async eval jobs) ────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Auth ───────────────────────────────────────────────────────────────────
# Used for local dev only — do not use in production
INTERNAL_API_KEY=dev_internal_key

# ── Alerting (optional) ────────────────────────────────────────────────────
# Slack incoming webhook URL for eval failure alerts
CORTEXOPS_SLACK_WEBHOOK_URL=

# Alert when task_completion drops below this threshold (0.0–1.0)
CORTEXOPS_ALERT_THRESHOLD=0.90

# Generic HTTP webhook (PagerDuty, OpsGenie, custom)
CORTEXOPS_WEBHOOK_URL=
CORTEXOPS_WEBHOOK_SECRET=

# ── LLM Judge (optional) ───────────────────────────────────────────────────
# Required only if using judge: llm in golden datasets
OPENAI_API_KEY=
# Alternative: use any OpenAI-compatible API
CORTEXOPS_JUDGE_API_KEY=

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# CORS_ORIGINS=https://getcortexops.com,https://app.getcortexops.com
